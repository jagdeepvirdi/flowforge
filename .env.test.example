# FlowForge — Test environment
# Copy this file to .env.test, fill in your local test DB credentials,
# then source it before running pytest:
#
#   source .env.test && pytest
#
# NEVER commit .env.test to version control (it is in .gitignore).
# The CI workflow sets these vars directly — see .github/workflows/test.yml.

# Dedicated test database (MUST be different from your production DB)
FLOWFORGE_DB_URL=postgresql://flowforge:yourpassword@localhost:5432/flowforge_test

# 64 hex chars = 32 bytes — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLOWFORGE_SECRET_KEY=

# Separate JWT signing secret (SEC-2) — generate the same way
FLOWFORGE_JWT_SECRET=
