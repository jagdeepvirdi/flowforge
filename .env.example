# ============================================================
# FlowForge — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- FlowForge System ------------------------------------------

# PostgreSQL password — used by docker-compose.yml for the bundled db service.
# Change this before deploying. Must match the password in FLOWFORGE_DB_URL.
POSTGRES_PASSWORD=changeme

# PostgreSQL connection string for FlowForge's own config database
FLOWFORGE_DB_URL=postgresql://flowforge:changeme@localhost:5432/flowforge

# Secret key for AES-256 credential encryption ONLY (generate once, keep safe)
# python -c "import secrets; print(secrets.token_hex(32))"
FLOWFORGE_SECRET_KEY=

# Separate secret for JWT signing — MUST be different from FLOWFORGE_SECRET_KEY
# python -c "import secrets; print(secrets.token_hex(32))"
FLOWFORGE_JWT_SECRET=

# Port the web server listens on
FLOWFORGE_PORT=5000

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
# Use DEBUG only in development — it logs SQL queries and internal steps.
LOG_LEVEL=INFO

# Seconds to wait for in-flight pipeline runs to finish on SIGTERM (default: 60)
# Set TimeoutStopSec in the systemd unit to this value + 30 so systemd doesn't
# SIGKILL the process before the drain completes.
FLOWFORGE_SHUTDOWN_TIMEOUT=60

# Allowed CORS origin for the frontend (required in production)
# Set to your actual domain, e.g. https://flowforge.yourcompany.com
FLOWFORGE_CORS_ORIGIN=

# Number of trusted reverse-proxy hops (0 = direct, 1 = behind nginx/ALB/Traefik)
# Required to make rate limiting work correctly behind a proxy (SEC-3)
FLOWFORGE_TRUSTED_PROXIES=0

# Maximum number of pipeline runs allowed to execute concurrently (default: 5)
# Excess requests receive HTTP 429. Raise this on high-core-count servers.
FLOWFORGE_MAX_CONCURRENT_RUNS=5

# Directory where generated report files are written
FLOWFORGE_OUTPUT_DIR=./output

# Delete output files older than this many days (0 = disabled)
# Applied automatically daily at 02:00 UTC when scheduler is running
# Also available manually: flowforge cleanup --days N
FLOWFORGE_OUTPUT_TTL_DAYS=7

# Default max attachment size before switching to Drive link (MB)
FLOWFORGE_ATTACHMENT_MAX_MB=10

# --- Authentication (v1 single-user) ---------------------------

FLOWFORGE_USERNAME=admin

# bcrypt hash of your password
# python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
FLOWFORGE_PASSWORD=

# --- Gmail OAuth2 ----------------------------------------------
# Set via: flowforge setup gmail
# Required for Gmail email provider and Google Drive upload

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=you@gmail.com

# --- Microsoft 365 OAuth2 (MSAL) -------------------------------
# Set via: flowforge setup microsoft365
# Requires an app registration in Azure AD

MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_SENDER_EMAIL=

# --- Google Drive ----------------------------------------------
# Shares OAuth2 credentials with Gmail if using the same account.
# Alternatively, set GOOGLE_SERVICE_ACCOUNT_FILE for a service account.

GOOGLE_DRIVE_FOLDER_ID=
# GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# --- User Databases (pipeline data sources) --------------------
# These are read by steps that reference a db_connection config.
# You can override per-connection in the UI; these are fallback defaults.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database
DB_USER=your_user
DB_PASSWORD=

# --- Audit Log -------------------------------------------------
# Write structured JSON audit lines to stdout (for container log aggregators)
FLOWFORGE_AUDIT_STDOUT=false

# Set to false to suppress writing to logs/audit.log (e.g. Docker where stdout is the log)
FLOWFORGE_AUDIT_FILE=true

# Only allow these env vars to be referenced in pipeline templates via {{ env.VAR }}
# If not set, all vars except known secrets are accessible (blocklist mode).
# Recommended: set an explicit allowlist in production.
# FLOWFORGE_TEMPLATE_ENV_VARS=DB_HOST,REPORT_DIR,APP_ENV

# SFTP strict host key checking — set true to reject unknown hosts
# Default false (TOFU) for compatibility; true recommended in production.
# When enabled, add host keys with: ssh-keyscan -H <host> >> ~/.ssh/known_hosts
FLOWFORGE_SFTP_STRICT_HOSTKEYS=false

# --- Production Server (Gunicorn) --------------------------------
# Number of Gunicorn worker processes.
# Formula: (2 × CPU_count) + 1. Start with 4 and tune under load.
# Each worker holds its own DB connection pool (SQLALCHEMY_POOL_SIZE connections).
GUNICORN_WORKERS=4

# Request timeout in seconds. Set higher for pipelines with long-running DB queries.
GUNICORN_TIMEOUT=120

# --- SQLAlchemy Connection Pool ----------------------------------
# Persistent connections per Gunicorn worker process (default: 5).
# Total max DB connections = GUNICORN_WORKERS × (POOL_SIZE + MAX_OVERFLOW).
SQLALCHEMY_POOL_SIZE=5

# Temporary extra connections above POOL_SIZE during traffic spikes (default: 10).
SQLALCHEMY_MAX_OVERFLOW=10

# Seconds to wait for a connection before raising OperationalError (default: 30).
SQLALCHEMY_POOL_TIMEOUT=30

# Recycle connections older than this many seconds (default: 1800 = 30 min).
# Prevents stale connections dropped by cloud load balancers or PgBouncer.
SQLALCHEMY_POOL_RECYCLE=1800

# --- Task Queue (Celery / Redis) --------------------------------
# When set, pipelines are dispatched to Celery workers instead of running in
# background threads.  Requires a Redis instance and at least one running worker:
#   flowforge worker        (or: celery -A flowforge.celery_app worker)
# Leave blank to use built-in threading mode (simpler; no Redis required).
FLOWFORGE_REDIS_URL=

# --- Monitoring (optional) -------------------------------------
# Flower Celery monitoring dashboard — start with: docker compose --profile monitoring up
# Basic auth credentials for the Flower UI (user:password).
# Change this before exposing Flower outside your internal network.
FLOWER_BASIC_AUTH=admin:changeme

# Port Flower listens on inside the container (default: 5555).
FLOWER_PORT=5555

# --- Compliance & Security (Phase 8) --------------------------

# Encrypt report output files at rest using FLOWFORGE_SECRET_KEY (AES-256-GCM).
# Files are decrypted transparently when downloaded via the UI.
# Recommended for regulated environments (finance, healthcare, SOC2).
FLOWFORGE_ENCRYPT_OUTPUT=false

# IP allowlist — only allow API requests from these CIDR ranges.
# Leave blank to allow all IPs. Multiple ranges separated by commas.
# Example: FLOWFORGE_ALLOWED_IPS=10.0.0.0/8,192.168.1.0/24,203.0.113.5/32
FLOWFORGE_ALLOWED_IPS=

# Base URL of the FlowForge frontend (used as OAuth2 redirect target for SSO).
FLOWFORGE_APP_URL=http://localhost:5000

# MFA issuer name shown in authenticator apps (default: FlowForge)
FLOWFORGE_MFA_ISSUER=FlowForge

# SSO — auto-create user accounts on first SSO login (default: false)
# When false, SSO users must already exist in FlowForge (matched by email).
FLOWFORGE_SSO_AUTO_CREATE=false

# --- Google SSO (Sign in with Google) -------------------------
# Separate from Gmail credentials — create a Web OAuth2 client in Google Cloud Console.
# Authorized redirect URIs must include: {FLOWFORGE_APP_URL}/api/auth/sso/google/callback
GOOGLE_SSO_CLIENT_ID=
GOOGLE_SSO_CLIENT_SECRET=

# --- Microsoft SSO (Sign in with Microsoft) -------------------
# Separate from Microsoft 365 mail credentials — create a Web app registration in Azure AD.
# Redirect URI must include: {FLOWFORGE_APP_URL}/api/auth/sso/microsoft/callback
MICROSOFT_SSO_TENANT_ID=
MICROSOFT_SSO_CLIENT_ID=
MICROSOFT_SSO_CLIENT_SECRET=

# --- AI Features (optional) ------------------------------------
# Set to false to disable all AI features and hide AI buttons in the UI.
# Useful if you don't want to install Ollama.
FLOWFORGE_AI_ENABLED=true

# Ollama endpoint (default, runs locally — no cost, no data leaves your machine)
OLLAMA_URL=http://localhost:11434

# Model used for chart suggestions and data profiling
OLLAMA_CHART_MODEL=llama3.2:3b

# Model used for SQL explain/optimize and pipeline failure diagnosis
OLLAMA_QUERY_MODEL=llama3.2:3b

# Set USE_CLAUDE=true to use Claude API instead of Ollama (ai_analyze step only)
USE_CLAUDE=false
ANTHROPIC_API_KEY=
